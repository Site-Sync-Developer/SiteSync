{
  "expo": {
    "name": "SiteSync Staff",
    "slug": "sitesync-staff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4a026f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitesync.staff",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos to send in chat.",
        "NSCameraUsageDescription": "Take photos to send in chat.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4a026f"
      },
      "package": "com.sitesync.staff"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "SiteSync Staff",
      "shortName": "SiteSync Staff",
      "display": "standalone",
      "favicon": "./assets/icon.png",
      "themeColor": "#4a026f",
      "backgroundColor": "#4a026f"
    },
    "extra": {
      "eas": {
        "projectId": "472dc3e4-9b5f-45bd-bfb0-44cce35b0184"
      }
    }
  }
}
