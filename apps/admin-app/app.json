{
  "expo": {
    "name": "SiteSync Admin",
    "slug": "sitesync-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4a026f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitesync.admin",
      "config": {
        "googleMapsApiKey": "AIzaSyAku6yvj27zW_4phLFucyY4TZhXBNBHQSM"
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos to send in chat.",
        "NSCameraUsageDescription": "Take photos to send in chat.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4a026f"
      },
      "package": "com.sitesync.admin",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAku6yvj27zW_4phLFucyY4TZhXBNBHQSM"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "SiteSync Admin",
      "shortName": "SiteSync Admin",
      "display": "standalone",
      "favicon": "./assets/icon.png",
      "themeColor": "#4a026f",
      "backgroundColor": "#4a026f"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4a026f",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "a5443789-24f8-4f03-916a-c3b83b11af68"
      }
    }
  }
}
