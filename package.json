{
  "name": "staff4dshire-rn",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "admin": "npm run start --workspace=admin-app",
    "staff": "npm run start --workspace=staff-app",
    "shared:build": "npm run build --workspace=@staff4dshire/shared",
    "backend:dev": "kill-port 3001 && npm run dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.1.3",
    "lodash": "^4.17.21",
    "react-dom": "^19.1.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "kill-port": "^2.0.1"
  },
  "overrides": {
    "expo-constants": "18.0.13",
    "expo-notifications": "0.32.16",
    "expo-application": "7.0.8",
    "expo-device": "~55.0.0"
  }
}
